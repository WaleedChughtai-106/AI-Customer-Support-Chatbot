{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://ai-chatbot-backend.onrender.com/api/$1"
    },
    {
      "source": "/style.css",
      "destination": "/frontend/style.css"
    },
    {
      "source": "/chat.js",
      "destination": "/frontend/chat.js"
    },
    {
      "source": "/",
      "destination": "/frontend/index.html"
    }
  ]
}